{
  "name": "@developerehsan/api-client-cli",
  "version": "1.0.0",
  "description": "OpenAPI codegen CLI for @developerehsan/api-client — generate typed TypeScript types and module descriptors, validate specs, and diff generated output.",
  "license": "MIT",
  "author": "EHSAN <ehsanshahid787@gmail.com>",
  "homepage": "https://github.com/developerEhsan/api-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developerEhsan/api-client.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/developerEhsan/api-client/issues"
  },
  "keywords": [
    "api-client",
    "openapi",
    "openapi-typescript",
    "codegen",
    "typegen",
    "cli",
    "typescript",
    "rest",
    "swagger"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "developerEhsan-api-client": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@developerehsan/api-client": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
