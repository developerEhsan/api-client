{
  "name": "@developerEhsan/api-client-query",
  "version": "0.1.0",
  "description": "TanStack Query v5 integration for @developerEhsan/api-client (React, Vue, Solid)",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "import": "./dist/solid.js",
      "require": "./dist/solid.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@developerEhsan/api-client": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "@tanstack/vue-query": ">=5.0.0",
    "@tanstack/solid-query": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": { "optional": true },
    "@tanstack/vue-query": { "optional": true },
    "@tanstack/solid-query": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
